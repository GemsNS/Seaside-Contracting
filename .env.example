# Copy to `.env.local` and fill in values.

# Resend — https://resend.com (create API key, verify sending domain for production)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where inquiries are delivered (defaults to info@seasidecontracting.ca if unset)
CONTACT_TO_EMAIL=info@seasidecontracting.ca

# Must be an address Resend allows for your account (verified domain or Resend sandbox)
RESEND_FROM_EMAIL=Seaside Contracting <onboarding@resend.dev>

# --- GitHub Pages / static export (optional) ---
# Full URL of /api/contact when the marketing site is static-only (e.g. Vercel deployment).
# NEXT_PUBLIC_CONTACT_API_URL=https://your-app.vercel.app/api/contact
# Subpath for project pages (usually set only in CI; leave unset for local dev).
# NEXT_PUBLIC_BASE_PATH=
